# Frontend - Environment variables (client/.env)
VITE_API_URL=http://localhost:5000/api  # Local development
# For production on Vercel, set this to your backend API URL

# Backend - Environment variables (.env)
PORT=5000
CLIENT_URL=http://localhost:5173  # Local development
# For production, set this to your frontend URL

SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
JWT_SECRET=your_jwt_secret
