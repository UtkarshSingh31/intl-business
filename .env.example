# Frontend - Environment variables (client/.env.local for development or .env for Vercel)
VITE_API_URL=http://localhost:5000/api  # Local: http://localhost:5000/api
                                          # Production: https://intl-business-backend.onrender.com

# Backend - Environment variables (.env)
PORT=5000
NODE_ENV=development                      # Change to 'production' for Render
CLIENT_URL=http://localhost:5173          # Local: http://localhost:5173
                                          # Production: https://intl-business.vercel.app

SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
JWT_SECRET=your_jwt_secret
